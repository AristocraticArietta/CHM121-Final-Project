---
import { elements } from "../scripts/periodic-table.js";
import { getGroupColor } from "../scripts/pt-populator.js";
 
// 1. Pre-package the entire Alpine state here on the server
const alpineState = JSON.stringify({
  isOpen: false,
  activeElement: null,
  allElements: elements
});

---

<div x-data={alpineState}>

  <div id="periodic-table" class="grid grid-cols-19 grid-rows-9 gap-0.5 p-2 w-full h-full">
    {elements.map((el) => (
      <div 
        class={`flex flex-col w-full items-center justify-center p-0.5 border border-gray-400 rounded-sm hover:scale-110 hover:z-10 transition-transform cursor-pointer shadow-sm ${getGroupColor(el.group)}`}
        style={`grid-column: ${el.col}; grid-row: ${el.row};`}

        data-symbol={el.symbol}

        @click="activeElement = allElements.find(e => e.symbol === $event.currentTarget.dataset.symbol); isOpen = true"
      >
        <span class="text-[0.5rem] self-start">{el.number}</span>
        <span class="text-xl font-bold">{el.symbol}</span>
        <span class="text-[0.5rem] truncate text-center ">{el.name}</span>
      </div>
    ))}
  </div>
  <div
    x-show="isOpen" 
    style="display: none;" 
    @click.self="isOpen = false"
    @keydown.window.escape="isOpen = false"
    class="fixed inset-0 bg-black/70 flex items-center justify-center z-50 backdrop-blur-md "
    x-transition.duration.500ms
  >
    <div class="glassmorphism-basic p-6 max-w-md w-full relative" @click.stop>
      
      <button @click="isOpen = false" class="absolute top-3 right-4 text-2xl text-gray-400 hover:text-white">&times;</button>
      
      <div class="flex items-end gap-4 mb-4 border-b border-gray-600 pb-4">
        <h2 x-text="activeElement?.symbol" class="text-5xl font-black"></h2>
        <div>
          <h3 x-text="activeElement?.name" class="text-2xl font-bold"></h3>
          <p class="text-sm text-gray-400">Atomic Number: <span x-text="activeElement?.number"></span></p>
        </div>
      </div>
      
      <div class="space-y-2 text-sm">
        <p><strong class="text-gray-300">Group:</strong> <span x-text="activeElement?.group.replace('-', ' ')" class="capitalize"></span></p>
        <p><strong class="text-gray-300">Standard Atomic Mass:</strong> <span x-text="activeElement?.atomicMass || 'Unknown'"></span></p>
        <p><strong class="text-gray-300">Discoverer(s):</strong> <span x-text="activeElement?.discoverer || 'Unknown'"></span></p>
        <p><strong class="text-gray-300">Year of Discovery:</strong> <span x-text="activeElement?.year || 'Unknown'"></span></p>
      </div>
    </div>
  </div>
</div>