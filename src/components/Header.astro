---
const { title } = Astro.props;
import "../styles/global.css";
---

<header class="sticky w-full h-(--header-height) flex flex-row justify-between items-center text-white bg-linear-to-r from-emerald-500 to-purple-500 ">
	<div class="font-bold px-2.5">{title}</div>
	<nav class="h-full w-1/3 flex justify-between items-center font-medium">
		<a href="/" id="header-link">Home</a>
		<a href="/about" id="header-link">About</a>
		<a href="/contact" id="header-link">Contact</a>
	</nav>
</header>

